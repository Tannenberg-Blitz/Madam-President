// Creates Hover effect

const hoverEffect = setInterval(function() {
    const portraitImages = document.querySelectorAll(".person_image img");

    portraitImages.forEach(img => {
        
        if (img.dataset.hoverActive) return;

        const currentSrc = img.src;
        let hoverSrc = "";

        if (currentSrc.includes("Hillary%20portait.jpg")) {
            hoverSrc = "https://file.garden/aPBWYPjiFyWz_Xv2/Clinton%202.png";
        } else if (currentSrc.includes("https://file.garden/aPBWYPjiFyWz_Xv2/campaign_2016_kaine-jpeg-57fa3.jpg")) { 
            hoverSrc = "https://file.garden/aPBWYPjiFyWz_Xv2/kaine%202.webp";
        }

        
        if (hoverSrc) {
            img.style.transition = "opacity 0.4s ease-in-out";
            
            img.addEventListener("mouseenter", function() {
                this.style.opacity = "0";
                setTimeout(() => {
                    this.src = hoverSrc;
                    this.style.opacity = "1";
                }, 200);
            });

            img.addEventListener("mouseleave", function() {
                this.style.opacity = "0";
                setTimeout(() => {
                    this.src = currentSrc;
                    this.style.opacity = "1";
                }, 200);
            });

            img.dataset.hoverActive = "true";
        }
    });
}, 1);


