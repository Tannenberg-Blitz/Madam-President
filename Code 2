function createKeySequenceListener(sequenceMap, maxLength = 10) {
    let keyBuffer = [];

    document.addEventListener('keydown', (event) => {
        keyBuffer.push(event.key);

        // Keep buffer within the max length
        if (keyBuffer.length > maxLength) {
            keyBuffer.shift();
        }

        const currentSequence = keyBuffer.join('');

        // Check all defined sequences
        for (const [pattern, callback] of Object.entries(sequenceMap)) {
            if (currentSequence.endsWith(pattern)) {
                callback();
                keyBuffer = []; // reset buffer after match
                break;
            }
        }
    });
}
