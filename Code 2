    function processStateUpdateQueue() {
        if (!stateUpdateQueue.length || animationFrameRequested) return;
        
        animationFrameRequested = true;
        
        requestAnimationFrame(() => {
            stateUpdateQueue.forEach(update => {
                update.shape.attr('fill', update.fill);
            });
            
            stateUpdateQueue.length = 0;
            animationFrameRequested = false;
            
            setTimeout(replaceMapHoverBehavior, 50);
        });
    }
    
    function replaceMapHoverBehavior() {
        const map = $('#map_container').data('plugin-usmap');
        if (!map || !map.stateShapes) return;
        
        if (map._hoverReplacementDone) return;
        map._hoverReplacementDone = true;
        
        const stateFills = {};
        
        // for each state shape, completely replace the hover behavior
        for (const stateAbbr in map.stateShapes) {
            const stateShape = map.stateShapes[stateAbbr];
            if (!stateShape || typeof stateShape.hover !== 'function') continue;
            
            stateFills[stateAbbr] = stateShape.attr('fill');
            
            stateShape.unhover();
            
            stateShape.hover(
                function() {
                    // get current fill for this state based on the active visualization mode
                    const currentFill = stateFills[stateAbbr];
                    
                    let hoverFill = "#AAAAAA";
                    
                    if (currentMode === VISUALIZATION_MODES.MARGINS && styleCache.margins[stateAbbr]) {
                        hoverFill = styleCache.margins[stateAbbr].hoverFill;
                    } else if (currentMode === VISUALIZATION_MODES.CANDIDATE_STRENGTH && 
                              styleCache.candidate_strength[stateAbbr] && 
                              styleCache.candidate_strength[stateAbbr][selectedCandidateIndex]) {
                        hoverFill = styleCache.candidate_strength[stateAbbr][selectedCandidateIndex].hoverFill;
                    } else if (currentMode === VISUALIZATION_MODES.COMPETITIVENESS && styleCache.competitiveness[stateAbbr]) {
                        hoverFill = styleCache.competitiveness[stateAbbr].hoverFill;
                    } else if (currentMode === VISUALIZATION_MODES.TURNOUT_CHANGE && styleCache.turnout_change[stateAbbr]) {
                        hoverFill = styleCache.turnout_change[stateAbbr].hoverFill;
                    } else if (currentMode === VISUALIZATION_MODES.SOLID && styleCache.solid[stateAbbr]) {
                        hoverFill = styleCache.solid[stateAbbr].hoverFill;
                    }
                    
                    this.attr('fill', hoverFill);
                    
                    this.toFront();
                    
                    if (map.options.click && typeof map.options.click === 'function') {
                        map.options.click(null, { name: stateAbbr });
                    }
                    
                    if (map.options.mouseover && typeof map.options.mouseover === 'function') {
                        map.options.mouseover(null, { name: stateAbbr });
                    }
                },
                function() {
                    this.attr('fill', stateFills[stateAbbr]);
                    
                    if (map.options.mouseout && typeof map.options.mouseout === 'function') {
                        map.options.mouseout(null, { name: stateAbbr });
                    }
                }
            );
        }
    }
    
    function updateMapStyles() {
        const map = $('#map_container').data('plugin-usmap');
        if (!map || !map.stateShapes) return;
        
        let styles;
        switch(currentMode) {
            case VISUALIZATION_MODES.MARGINS:
                styles = styleCache.margins;
                break;
            case VISUALIZATION_MODES.CANDIDATE_STRENGTH:
                styles = {};
                for (const stateAbbr in styleCache.candidate_strength) {
                    if (styleCache.candidate_strength[stateAbbr][selectedCandidateIndex]) {
                        styles[stateAbbr] = styleCache.candidate_strength[stateAbbr][selectedCandidateIndex];
                    } else {
                        styles[stateAbbr] = { fill: "#EEEEEE", hoverFill: "#DDDDDD" };
                    }
                }
                break;
            case VISUALIZATION_MODES.COMPETITIVENESS:
                styles = styleCache.competitiveness;
                break;
            case VISUALIZATION_MODES.TURNOUT_CHANGE:
                styles = styleCache.turnout_change;
                break;
            default:
                styles = styleCache.solid;
        }
        
        const stateFills = {};
        
        stateUpdateQueue.length = 0;
        
        for (const stateAbbr in styles) {
            if (map.stateShapes[stateAbbr]) {
                stateFills[stateAbbr] = styles[stateAbbr].fill;
                
                stateUpdateQueue.push({
                    shape: map.stateShapes[stateAbbr],
                    fill: styles[stateAbbr].fill
                });
            }
        }
        
        processStateUpdateQueue();
    }
    
