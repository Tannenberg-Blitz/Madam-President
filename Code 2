    // calculate percentiles for an array of values
    function calculatePercentile(values, percentile) {
        if (!values || values.length === 0) return 0;
        const sortedValues = [...values].sort((a, b) => a - b);
        const index = Math.floor(sortedValues.length * (percentile / 100));
        return sortedValues[index];
    }
    
    // get turnout change data using game state information
    function getTurnoutChangeData() {
        const turnoutChangeData = {};
        
        campaignTrail_temp.states_json.forEach(state => {
            const stateId = state.pk;
            
            let actualVotes = 0;
            const stateResults = campaignTrail_temp.final_state_results.find(r => r.state === stateId);
            
            if (stateResults && stateResults.result) {
                stateResults.result.forEach(candidateResult => {
                    actualVotes += candidateResult.votes || 0;
                });
            } else {
                // use expected turnout if no results available
                actualVotes = state.fields.popular_votes;
            }
            
            // calculate turnout change percentage
			// if we haven't given up on TurnoutSystem, use that data instead
            const originalTurnout = campaignTrail_temp.TurnoutSystem?.originalTurnouts?.[stateId] || state.fields.popular_votes;
            const changePercent = ((actualVotes - originalTurnout) / originalTurnout) * 100;
            turnoutChangeData[stateId] = changePercent;
        });
        
        return turnoutChangeData;
    }
    
    function analyzePerformanceData() {
        const candidates = [];
        campaignTrail_temp.final_state_results[0].result.forEach(result => {
            const candidate = campaignTrail_temp.candidate_json.find(c => c.pk === result.candidate);
            if (candidate) candidates.push(candidate);
        });
        
        candidateMaxPercentages = {};
        candidates.forEach(candidate => {
            candidateMaxPercentages[candidate.pk] = {
                max: 0,
                min: 1,
                avg: 0,
                median: 0,
                counts: 0,
                percentiles: []
            };
        });
        
        // analyze all states to find each candidate's performance range
        campaignTrail_temp.final_state_results.forEach(stateResult => {
            stateResult.result.forEach(candidateResult => {
                const candidateData = candidateMaxPercentages[candidateResult.candidate];
                if (candidateData) {
                    candidateData.max = Math.max(candidateData.max, candidateResult.percent);
                    candidateData.min = Math.min(candidateData.min, candidateResult.percent);
                    candidateData.avg += candidateResult.percent;
                    candidateData.counts++;
                    candidateData.percentiles.push(candidateResult.percent);
                }
            });
        });
        
        // calculate averages, percentiles, and other statistics
        Object.values(candidateMaxPercentages).forEach(data => {
            if (data.counts > 0) {
                data.avg /= data.counts;
                data.percentiles.sort((a, b) => a - b);
                
                // calculate median (50th percentile)
                const midIndex = Math.floor(data.percentiles.length / 2);
                data.median = data.percentiles.length % 2 === 0
                    ? (data.percentiles[midIndex - 1] + data.percentiles[midIndex]) / 2
                    : data.percentiles[midIndex];
                
                // calculate 10th and 90th percentiles
                data.p10 = calculatePercentile(data.percentiles, 10);
                data.p90 = calculatePercentile(data.percentiles, 90);
            }
        });
    }
    
    // get dynamic percentage thresholds for a candidate based on their actual performance
    function getPerformanceThresholds(candidatePk) {
        const data = candidateMaxPercentages[candidatePk];
        if (!data || data.counts === 0) return [0.6, 0.5, 0.4, 0.3, 0.2, 0.1, 0.05];
        
        const maxPct = Math.max(data.max, 0.01); // ensure we don't divide by zero
        const p90 = data.p90; // 90th percentile
        
        // if there's a big gap between max and 90th percentile, use the 90th percentile
        // this handles outliers like a candidate getting 90% in their home state
        if (maxPct > 0.40) {
            // Major candidate (>40% max) - create more granular thresholds at the higher end
            if (maxPct - p90 > 0.15) {
                // case with outliers - create thresholds around typical performance
                return [
                    maxPct, // absolute max
                    p90 + ((maxPct - p90) * 0.5), // halfway between max and p90
                    p90,
                    data.avg + ((p90 - data.avg) * 0.5),
                    data.avg,
                    data.p10,
                    data.min
                ].filter((v, i, a) => i === 0 || v < a[i-1] * 0.95); // remove too-close thresholds
            } else {
                // Normal distribution - create evenly spaced thresholds
                return [
                    maxPct,
                    Math.max(maxPct * 0.95, maxPct - 0.04), // Very close to max
                    Math.max(maxPct * 0.90, maxPct - 0.08), // Strong performance
                    Math.max(maxPct * 0.80, maxPct - 0.15), // Good performance
                    Math.max(maxPct * 0.65, maxPct - 0.25), // Moderate performance
                    Math.max(maxPct * 0.50, maxPct - 0.35), // Below average
                    Math.max(maxPct * 0.30, maxPct - 0.45)  // Weak performance
                ];
            }
        } else if (maxPct > 0.10) {
            // Medium candidate (10-40% max)
            return [
                maxPct,
                maxPct * 0.8,
                maxPct * 0.6,
                maxPct * 0.4,
                maxPct * 0.25,
                maxPct * 0.15
            ];
        } else if (maxPct > 0.03) {
            // Minor candidate (3-10% max)
            return [
                maxPct,
                maxPct * 0.75,
                maxPct * 0.5, 
                maxPct * 0.25,
                maxPct * 0.1
            ];
        } else {
            // Very minor candidate (<3% max)
            // Create meaningful small ranges
            const step = maxPct / 4;
            return [
                maxPct,
                maxPct - step,
                maxPct - (step * 2),
                maxPct - (step * 3),
                0
            ].filter(v => v > 0);
        }
    }
    
    // format percentage threshold for display
    function formatThreshold(value) {
        if (value >= 0.01) {
            return Math.round(value * 100) + '%';
        } else {
            return (value * 100).toFixed(1) + '%';
        }
    }
    
    // apply color variations to candidates
    function applyColorVariations() {
        if (!window._colorVariationsApplied) {
            campaignTrail_temp.candidate_json.forEach(candidate => {
                const fields = candidate.fields;
                
                // store original colors for reference
                if (!fields._original_color_hex) {
                    fields._original_color_hex = fields.color_hex;
                    fields._original_secondary_color_hex = fields.secondary_color_hex || fields.color_hex;
                }
                
                fields.color_hex = varyHexColor(fields._original_color_hex, 0.05);
                
                if (fields.secondary_color_hex) {
                    fields.secondary_color_hex = varyHexColor(fields._original_secondary_color_hex, 0.05);
                } else {
                    // create a secondary color if none exists
                    const primaryRGB = hexToRgb(fields.color_hex);
                    const whiteRGB = [255, 255, 255];
                    const secondaryRGB = interpolateColor(primaryRGB, whiteRGB, 0.7);
                    fields.secondary_color_hex = rgbToHex(...secondaryRGB);
                }
            });
            
            // apply variations to historical colors if they exist
            if (window.HistHexcolour && Array.isArray(window.HistHexcolour)) {
                window.HistHexcolour = window.HistHexcolour.map(hex => 
                    varyHexColor(hex, 0.05)
                );
            }
            
            window._colorVariationsApplied = true;
        }
    }
    
    // identify top candidates (for margin legend)
    function getTopCandidates(limit = 3) {
        const candidates = [];
        
        campaignTrail_temp.final_overall_results.forEach(result => {
            const candidate = campaignTrail_temp.candidate_json.find(c => c.pk === result.candidate);
            if (candidate) candidates.push({
                pk: result.candidate,
                candidate: candidate,
                electoral_votes: result.electoral_votes,
                popular_votes: result.popular_votes
            });
        });
        
        // sort by electoral votes
        candidates.sort((a, b) => b.electoral_votes - a.electoral_votes);
        
        // take top candidates
        const totalEV = candidates.reduce((sum, c) => sum + c.electoral_votes, 0);
        const majorCandidateThreshold = totalEV * 0.1; // 10% of EVs
        
        // return top candidates that meet threshold or at least top 2
        return candidates
            .filter((c, i) => c.electoral_votes >= majorCandidateThreshold || i < 2)
            .slice(0, limit);
    }
    
